# ===== CS2 server =====
CS2_PORT=27015
CS2_TV_PORT=27020
CS2_TICKRATE=64
CS2_REGION=3
CS2_LAN=0

CS2_MAXPLAYERS=10
CS2_GAMEMODE=competitive
CS2_HOTNAME=CS2 Dedicated Server

# ===== Auth =====
CS2_RCON_PASSWORD=changeme-rcon
CS2_SERVER_PASSWORD=

# GSLT (Game Server Login Token) — required for public server browser listing.
# Without it: server still runs, can be joined via "connect IP:port" from client console.
# Get one: https://steamcommunity.com/dev/managegameservers (app 730)
CS2_GSLT=

# Steam Web API key — required ONLY for hosting workshop maps via +host_workshop_map.
# Get one: https://steamcommunity.com/dev/apikey
CS2_AUTHKEY=

# Admin Steam64 ID for MatchZy + CSS (set your own: STEAMID64 from steamid.io)
CS2_ADMIN_STEAMID=76561198104682187

# ===== Workshop (optional) =====
CS2_HOST_WORKSHOP_MAP=
CS2_WORKSHOP_COLLECTION=

# ===== GOTV =====
CS2_TV_ENABLE=1
CS2_TV_DELAY=0

# ===== MySQL (consumed by MatchZy stats + cs2-WeaponPaints) =====
CS2_MYSQL_HOST=mysql
CS2_MYSQL_PORT=3306
CS2_MYSQL_USER=cs2
CS2_MYSQL_PASS=changeme-cs2
CS2_MYSQL_DB_WEAPON=weaponpaints
CS2_MYSQL_DB_MATCH=matchzy
MYSQL_ROOT_PASSWORD=changeme-root

# ===== Misc =====
CS2_EXTRA_ARGS=
TZ=UTC
